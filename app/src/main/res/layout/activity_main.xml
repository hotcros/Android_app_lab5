<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/main_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center"
        android:background="#FFFFFF">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Сенсори пристрою"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:id="@+id/text_light"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Освітлення: очікування..."
            android:textSize="18sp"
            android:layout_marginBottom="16dp"
            android:textAlignment="center"/>

        <TextView
            android:id="@+id/text_proximity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Наближення: очікування..."
            android:textSize="18sp"
            android:textAlignment="center"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/screen_off_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#000000"
        android:gravity="center"
        android:visibility="gone"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Екран вимкнено"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="(Спрацював датчик наближення)"
            android:textColor="#AAAAAA"
            android:textSize="16sp"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

</FrameLayout>